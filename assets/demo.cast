[14.492179, "o", "                                                                                                                                                               \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                                         \r\n                                                                                                                                                                                   